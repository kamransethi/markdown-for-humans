{
  "name": "gpt-ai-markdown-editor",
  "displayName": "GPT-AI Markdown Editor",
  "description": "A full-featured WYSIWYG Markdown editor with visual table editing, drag-and-drop images, Mermaid diagrams, and distraction-free writing—all inside VS Code.",
  "version": "1.0.0",
  "publisher": "kamransethi",
  "author": {
    "name": "Kamran Sethi",
    "email": "kamransethi@hotmail.com"
  },
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kamransethi/gpt-ai-markdown-editor"
  },
  "bugs": {
    "url": "https://github.com/kamransethi/gpt-ai-markdown-editor/issues"
  },
  "homepage": "https://github.com/kamransethi/gpt-ai-markdown-editor#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "markdown",
    "editor",
    "wysiwyg",
    "preview",
    "visual",
    "md",
    "table",
    "tables",
    "mermaid",
    "diagram",
    "image",
    "drag-drop",
    "github-flavored-markdown",
    "gfm",
    "notion-like",
    "writing",
    "documentation",
    "readme",
    "formatting",
    "syntax-highlighting",
    "live-preview",
    "full-screen",
    "distraction-free",
    "cover-images",
    "image-resizing",
    "export",
    "html",
    "pdf",
    "docx",
    "human-friendly"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "gptAiMarkdownEditor.editor",
        "displayName": "GPT-AI Markdown Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "gptAiMarkdownEditor.openFile",
        "title": "Open with GPT-AI Markdown Editor"
      },
      {
        "command": "gptAiMarkdownEditor.outline.revealCurrent",
        "title": "Outline: Reveal Current Heading",
        "icon": "$(target)"
      },
      {
        "command": "gptAiMarkdownEditor.outline.filter",
        "title": "Outline: Filter Headings",
        "icon": "$(search)"
      },
      {
        "command": "gptAiMarkdownEditor.outline.clearFilter",
        "title": "Outline: Clear Filter",
        "icon": "$(close)"
      },
      {
        "command": "gptAiMarkdownEditor.openAttachmentsFolder",
        "title": "Open Attachments Folder"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "gptAiMarkdownEditorOutline",
          "name": "GPT-AI Markdown Editor: Outline",
          "when": "gptAiMarkdownEditor.isActive",
          "icon": "$(layout-sidebar-right)"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "gptAiMarkdownEditor.openFile",
          "when": "resourceExtname == .md",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "gptAiMarkdownEditor.outline.revealCurrent",
          "when": "view == gptAiMarkdownEditorOutline",
          "group": "navigation@1"
        },
        {
          "command": "gptAiMarkdownEditor.outline.filter",
          "when": "view == gptAiMarkdownEditorOutline && !gptAiMarkdownEditor.outlineFilterActive",
          "group": "navigation@2"
        },
        {
          "command": "gptAiMarkdownEditor.outline.clearFilter",
          "when": "view == gptAiMarkdownEditorOutline && gptAiMarkdownEditor.outlineFilterActive",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "GPT-AI Markdown Editor",
      "properties": {
        "gptAiMarkdownEditor.mediaPath": {
          "type": "string",
          "default": "media",
          "description": "Subfolder name for saved media files (images, attachments). Only used when Media Path Base is 'relativeToDocument' or 'workspaceFolder'."
        },
        "gptAiMarkdownEditor.mediaPathBase": {
          "type": "string",
          "enum": [
            "sameNameFolder",
            "relativeToDocument",
            "workspaceFolder"
          ],
          "enumDescriptions": [
            "Save media in a folder with the same name as the markdown file (e.g., my-doc/ next to my-doc.md). Recommended.",
            "Save media in a subfolder relative to the current markdown file's directory.",
            "Save media in a subfolder relative to the workspace root."
          ],
          "default": "sameNameFolder",
          "description": "Controls where media files (images, attachments) are saved."
        },
        "gptAiMarkdownEditor.chromePath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to Google Chrome or Chromium executable for PDF export. Leave empty to auto-detect.\n\n**Download Chrome:**\n- [Windows/Mac/Linux](https://www.google.com/chrome/)\n- [Chromium (open source)](https://www.chromium.org/getting-involved/download-chromium/)\n\n**Common paths:**\n- **Mac:** `/Applications/Google Chrome.app/Contents/MacOS/Google Chrome`\n- **Windows:** `C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe`\n- **Linux:** `/usr/bin/google-chrome` or `/usr/bin/chromium`"
        },
        "gptAiMarkdownEditor.imageResize.skipWarning": {
          "type": "boolean",
          "default": false,
          "description": "Skip the warning dialog when resizing images. When enabled, images will be resized immediately without confirmation."
        },
        "gptAiMarkdownEditor.lineSpacing": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 3,
          "description": "Line height multiplier for body text in the editor (e.g., 1.7 = 170% of font size)."
        },
        "gptAiMarkdownEditor.paragraphSpacing": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 3,
          "description": "Extra bottom margin between paragraphs, in em units."
        },
        "gptAiMarkdownEditor.tableCellSpacing": {
          "type": "number",
          "default": 0.1,
          "minimum": 0,
          "maximum": 2,
          "description": "Vertical padding inside table cells, in em units."
        },
        "gptAiMarkdownEditor.tableCellHorizontalSpacing": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 3,
          "description": "Horizontal padding inside table cells, in em units."
        },
        "gptAiMarkdownEditor.themeOverride": {
          "type": "string",
          "enum": [
            "system",
            "light",
            "dark"
          ],
          "default": "system",
          "description": "Override the editor theme mode (System, Light, or Dark) manually. Choosing System will follow your VS Code theme."
        },
        "gptAiMarkdownEditor.developerMode": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "**Developer Mode**: Show detailed runtime errors in-editor and keep diagnostic logging enabled for troubleshooting.",
          "order": 999
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:release",
    "build:debug": "npm run build:extension:debug && npm run build:webview:debug",
    "build:release": "npm run build:extension:release && npm run build:webview:release && npm run verify-build",
    "verify-build": "node scripts/verify-build.js",
    "build:extension:debug": "node scripts/build-extension.js",
    "build:extension:release": "node scripts/build-extension.js --prod --no-sourcemap",
    "build:webview:debug": "node scripts/build-webview.js",
    "build:webview:release": "node scripts/build-webview.js --prod --no-sourcemap",
    "watch:debug": "concurrently \"npm run watch:extension:debug\" \"npm run watch:webview:debug\"",
    "watch:extension:debug": "node scripts/build-extension.js --watch",
    "watch:webview:debug": "node scripts/build-webview.js --watch",
    "lint": "eslint src --ext ts --max-warnings 600",
    "lint:fix": "eslint src --ext ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "precommit": "npm run lint && npm run test",
    "validate": "npm run lint && npm run test && npm run build:debug",
    "package:release": "vsce package",
    "vsix": "npm run build:release && vsce package",
    "publish:release": "vsce publish",
    "publish:ovsx:release": "npm run build:release && ovsx publish",
    "install-hooks": "bash ./scripts/install-git-hooks.sh"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@tiptap/extension-table-cell": "^3.20.1",
    "@tiptap/extension-table-header": "^3.20.1",
    "@tiptap/extension-table-row": "^3.20.1",
    "@types/image-size": "^0.7.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vscode/vsce": "^3.7.1",
    "concurrently": "^8.2.2",
    "esbuild": "^0.27.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@tiptap/core": "^3.0.0",
    "@tiptap/extension-code-block-lowlight": "^3.0.0",
    "@tiptap/extension-color": "^3.20.1",
    "@tiptap/extension-drag-handle": "^3.20.1",
    "@tiptap/extension-highlight": "^3.12.1",
    "@tiptap/extension-image": "^3.0.0",
    "@tiptap/extension-link": "^3.0.0",
    "@tiptap/extension-list": "^3.0.0",
    "@tiptap/extension-table": "^3.0.0",
    "@tiptap/extension-text-style": "^3.20.1",
    "@tiptap/extension-underline": "^3.20.1",
    "@tiptap/markdown": "^3.0.0",
    "@tiptap/pm": "^3.0.0",
    "@tiptap/starter-kit": "^3.0.0",
    "@types/turndown": "^5.0.4",
    "cheerio": "^1.1.2",
    "docx": "^9.5.1",
    "highlight.js": "^11.11.1",
    "image-size": "^2.0.2",
    "katex": "^0.16.9",
    "lowlight": "^2.9.0",
    "markdown-it": "^14.0.0",
    "markdown-it-mark": "^4.0.0",
    "mermaid": "^11.12.3",
    "turndown": "^7.1.2"
  }
}